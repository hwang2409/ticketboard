{
  "name": "ticketboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "brief:codex": "node scripts/generate-workflow-brief.mjs",
    "brief:snapshot": "node scripts/generate-workflow-brief.mjs --dry-run",
    "dev": "uv run python -m server.app",
    "screenshots:readme": "node scripts/capture-readme-screenshots.mjs",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && uv run ruff check server",
    "lint:py": "uv run ruff check server",
    "verify:ui": "node scripts/verify-ui.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "@xyflow/react": "^12.10.2",
    "express": "^5.2.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "playwright": "^1.60.0",
    "typescript-eslint": "^8.50.0"
  }
}
